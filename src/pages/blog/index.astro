---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const blogs = await getCollection('blog');
blogs.sort((a, b) => new Date(b.data.updated || b.data.date).getTime() - new Date(a.data.updated || a.data.date).getTime());

const base = import.meta.env.BASE_URL === '/' ? '/' : import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Layout>
  <main class="app-shell">
    <h2 class="view-title">博客</h2>
    <p class="view-sub">技术博客与随想</p>

    {blogs.length > 0 ? (
      <div class="blog-list">
        {blogs.map(blog => (
          <a href={`${base}blog/${blog.slug}/`} class="blog-card">
            <div class="blog-card-title">{blog.data.title}</div>
            {blog.data.description && <p class="blog-card-desc">{blog.data.description}</p>}
            <div class="blog-card-meta">{blog.data.date}</div>
            {blog.data.tags.length > 0 && (
              <div class="blog-card-tags">
                {blog.data.tags.map(t => <span class="blog-tag">{t}</span>)}
              </div>
            )}
          </a>
        ))}
      </div>
    ) : (
      <section class="empty-state">还没有博客文章</section>
    )}
  </main>
</Layout>
