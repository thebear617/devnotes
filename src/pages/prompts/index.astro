---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const prompts = await getCollection('prompts');
prompts.sort((a, b) => new Date(b.data.updated || b.data.date).getTime() - new Date(a.data.updated || a.data.date).getTime());

const allTags = [...new Set(prompts.flatMap(p => p.data.tags))].sort();
const base = import.meta.env.BASE_URL === '/' ? '/' : import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Layout>
  <main class="app-shell">
    <h2 class="view-title">提示词库</h2>
    <p class="view-sub">收藏值得反复用的提示词与场景</p>

    <div class="list-search" id="promptSearch">
      <span class="list-search-icon">🔍</span>
      <input
        type="search"
        id="promptSearchInput"
        class="list-search-input"
        placeholder="搜索标题、描述或标签"
        autocomplete="off"
        aria-label="搜索提示词"
      />
      <button class="list-search-clear" id="promptSearchClear" aria-label="清除搜索">✕</button>
    </div>

    {allTags.length > 0 && (
      <div class="filter-bar" id="filterBar">
        <div class="filter-row">
          <span class="filter-label">标签</span>
          <div class="filter-tags" data-filter="tags">
            {allTags.map(t => <button class="filter-tag">{t}</button>)}
            <button class="filter-clear" id="filterClear">清除筛选</button>
          </div>
        </div>
      </div>
    )}

    {prompts.length > 0 ? (
      <div class="blog-list" id="promptList">
        {prompts.map(p => (
          <a
            href={`${base}prompts/${p.slug}/`}
            class="blog-card"
            data-tags={p.data.tags.join(',')}
            data-title={p.data.title}
            data-desc={p.data.description || ''}
          >
            <div class="blog-card-title">{p.data.title}</div>
            {p.data.description && <p class="blog-card-desc">{p.data.description}</p>}
            <div class="blog-card-meta">{p.data.date}</div>
            {p.data.tags.length > 0 && (
              <div class="blog-card-tags">
                {p.data.tags.map(t => <span class="blog-tag">{t}</span>)}
              </div>
            )}
          </a>
        ))}
      </div>
    ) : (
      <section class="empty-state">还没有提示词</section>
    )}

    <section class="empty-state" id="emptyState" style="display:none">没有匹配的提示词</section>
  </main>
</Layout>

<script>
  let filters = {};
  let searchTerm = '';

  document.querySelectorAll('.filter-bar .filter-tag').forEach(tag => {
    tag.addEventListener('click', () => {
      const row = tag.closest('.filter-row');
      const filterKey = row.querySelector('.filter-tags').dataset.filter;
      const on = tag.classList.toggle('on');
      if (on) {
        row.querySelectorAll('.filter-tag').forEach(t => { if (t !== tag) t.classList.remove('on'); });
        filters[filterKey] = tag.textContent;
      } else {
        delete filters[filterKey];
      }
      applyFilters();
    });
  });

  const filterClear = document.getElementById('filterClear');
  filterClear?.addEventListener('click', () => {
    document.querySelectorAll('.filter-bar .filter-tag.on').forEach(t => t.classList.remove('on'));
    filters = {};
    applyFilters();
  });

  const searchInput = document.getElementById('promptSearchInput');
  const searchClear = document.getElementById('promptSearchClear');
  searchInput.addEventListener('input', () => {
    searchTerm = searchInput.value.trim().toLowerCase();
    searchClear.style.display = searchTerm ? '' : 'none';
    applyFilters();
  });
  searchClear.addEventListener('click', () => {
    searchInput.value = '';
    searchTerm = '';
    searchClear.style.display = 'none';
    searchInput.focus();
    applyFilters();
  });

  function applyFilters() {
    const visible = [];
    document.querySelectorAll('#promptList .blog-card').forEach(card => {
      let show = true;
      if (filters.tags && !card.dataset.tags.split(',').includes(filters.tags)) show = false;
      if (show && searchTerm) {
        const haystack = (card.dataset.title + ' ' + card.dataset.desc + ' ' + card.dataset.tags).toLowerCase();
        show = haystack.includes(searchTerm);
      }
      card.style.display = show ? '' : 'none';
      if (show) visible.push(card);
    });
    document.getElementById('emptyState').style.display = visible.length ? 'none' : '';
  }
</script>